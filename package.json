{
  "name": "rss2pod",
  "version": "3.0.0",
  "description": "Convert RSS feeds to podcast feeds with AI-powered content enhancement",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "rss2pod": "./dist/cli/index.js"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "cli": "tsx src/cli/index.ts",
    "tui": "tsx src/tui/index.tsx",
    "api": "tsx src/api/index.ts",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "rss",
    "podcast",
    "automation",
    "llm",
    "tts",
    "audio"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@fastify/cors": "^10.0.2",
    "@fastify/static": "^8.1.1",
    "axios": "^1.7.9",
    "better-sqlite3": "^11.8.1",
    "commander": "^13.1.0",
    "cron-parser": "^5.5.0",
    "eventemitter2": "^6.4.9",
    "fastify": "^5.2.1",
    "ink": "^6.8.0",
    "node-cron": "^4.2.1",
    "pino": "^9.6.0",
    "podcast": "^2.0.1",
    "react": "^19.2.4",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.7",
    "@types/react": "^19.2.14",
    "@typescript-eslint/eslint-plugin": "^8.21.0",
    "@typescript-eslint/parser": "^8.21.0",
    "eslint": "^9.18.0",
    "ink-testing-library": "^4.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
